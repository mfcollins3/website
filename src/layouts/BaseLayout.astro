---
import FontAwesome from '../components/FontAwesome.astro';
import Footer from '../components/Footer.astro';
import GlobalStyles from '../components/GlobalStyles.astro';
import NavigationBar from '../components/NavigationBar.astro';
import Fonts from '../components/Fonts.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';

interface Props {
    title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
    <head>
        <title>{title}</title>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <FontAwesome />
        <GlobalStyles />
        <Fonts />
        <GoogleAnalytics />
    </head>
    <body>
        <div class="navigation">
            <div class="navbar">
                <NavigationBar />
            </div>
        </div>
        <div class="content">
            <slot />
        </div>
        <footer>
            <div class="footer">
                <Footer />
            </div>
        </footer>
    </body>
</html>

<style>
body {
    height: 100dvh;
}

.content {
    position: relative;
    z-index: 1;
    min-height: 100dvh;
    background: white;
    box-shadow: 0px 20px 40px #00000010;
}

footer {
    position: sticky;
    bottom: 0;
    padding: 1rem 0;

    display: grid;
    grid-template-columns: 1fr minmax(auto, 1136px) 1fr;
}

.footer {
    grid-column: 2 / 3;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2rem;
}

.navigation {
    z-index: 100;
    position: fixed;
    width: 100dvw;
    top: 1rem;

    display: grid;
    grid-template-columns: 1fr minmax(auto, 1136px) 1fr;
}

.navbar {
    grid-column: 2 / 3;
    padding: 0 6rem;
}

@media (max-width: 500px) {
    footer {
        display: block;
        margin: 0 1rem;
    }

    .footer {
        display: block;
    }

    .navigation {
        z-index: 100;
        position: fixed;
        top: 0;
        display: block;
    }

    .navbar {
        padding: 0;
    }

    .content {
        padding-top: 4rem;
    }
}
</style>