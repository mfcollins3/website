---
import type { ImageMetadata } from "astro";
import { getImage } from "astro:assets";

interface Props {
    mobileImageURL: string | ImageMetadata;
    desktopImageURL: string | ImageMetadata;
    alt: string;
}

const { mobileImageURL, desktopImageURL, alt } = Astro.props;

const mobileImage = await getImage({
    src: mobileImageURL,
    format: "webp",
    width: 502,
    height: 300,
});
const desktopImage = await getImage({
    src: desktopImageURL,
    format: "webp",
    width: 1920,
    height: 496,
});

const style = `background-image: url(${desktopImage.src}); @media (max-width: 502px) { background-image: url(${mobileImage.src}); }`;
---
<div class="cover-image" style={style} />

<style>
    .cover-image {
        width: 100%;
        height: 496px;
        background-position: center;
        background-size: cover;
        background-repeat: no-repeat;
    }

    @media (max-width: 500px) {
        .cover-image {
            height: 300px;
        }
    }
</style>